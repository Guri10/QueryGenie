FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Install system dependencies (minimal, remove build tools after use)
RUN apt-get update && apt-get install -y \
    curl \
    build-essential \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Copy requirements first for better caching
COPY requirements.txt .

# Install CPU-only PyTorch first to avoid CUDA dependencies (prevents 706MB nvidia_cudnn download)
# Use compatible versions: PyTorch 2.2.0+ works better with transformers
# This significantly speeds up builds on free tier
RUN pip install --no-cache-dir \
    torch==2.2.0 torchvision==0.17.0 torchaudio==2.2.0 \
    --index-url https://download.pytorch.org/whl/cpu

# Install remaining Python dependencies with cleanup
RUN pip install --no-cache-dir -r requirements.txt && \
    pip cache purge && \
    rm -rf /tmp/* /var/tmp/* /root/.cache/pip && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Copy source code
COPY src/ ./src/
COPY backend/ ./backend/

# Create data and models directories
RUN mkdir -p data models

# Copy FAISS index files (for free tier - no persistent disks)
# These files are small enough (~60MB total) to include in image
COPY data/faiss_index.faiss ./data/faiss_index.faiss
COPY data/faiss_index_chunks.json ./data/faiss_index_chunks.json

# Set environment variables
ENV PYTHONPATH=/app/src
ENV USE_LLM=true
ENV HOST=0.0.0.0
ENV PORT=8000

# Expose port
EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8000/api/v1/health || exit 1

# Run the application
CMD ["python", "backend/main.py"]
